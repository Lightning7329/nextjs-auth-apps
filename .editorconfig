root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{html,css,scss}]
indent_size = 2

[*.{js,ts,tsx}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[.vscode/*.json]
indent_size = 4

[*.code-workspace]
indent_size = 4

[*.{md,mdx}]
indent_size = 4
